# ytta

ssh alwaysdata

ssh -i ~/.ssh/alwaysdata_ed25519 allbibek@ssh-allbibek.alwaysdata.net

ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIKQQwGl8erh81wK537JgwMb55JqUIsWmTweCxMRtovSG codespace->alwaysdata.net

sed -n '1,200p' ~/.ssh/config

cat <<'EOF' | tee -a ~/.ssh/config >/dev/null
Host alwaysdata
  HostName ssh-allbibek.alwaysdata.net
  User allbibek
  IdentityFile ~/.ssh/alwaysdata_ed25519
  IdentitiesOnly yes
EOF

chmod 600 ~/.ssh/config (non eksekusi)

